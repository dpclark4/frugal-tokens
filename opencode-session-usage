#!/usr/bin/env -S deno run --allow-env=OPENCODE_DB_PATH,HOME --allow-read

import { DatabaseSync } from "node:sqlite";
import { analyzeSessionCache } from "./src/server/cacheAnalysis.ts";
import { OpenCodeRepository } from "./src/server/opencodeRepository.ts";
import { priceSessionDetail } from "./src/server/pricing.ts";

function usage(): never {
  console.error("Usage: opencode-session-usage [session-id] [database]");
  Deno.exit(1);
}

if (Deno.args.length > 2) usage();

const requestedSession = Deno.args[0];
const databasePath = Deno.args[1] ?? Deno.env.get("OPENCODE_DB_PATH") ??
  `${Deno.env.get("HOME")}/.local/share/opencode/opencode.db`;

let sessionID: string | undefined = requestedSession;
if (!sessionID) {
  const database = new DatabaseSync(databasePath, { readOnly: true });
  try {
    const row = database.prepare(`
      SELECT id
      FROM session
      WHERE parent_id IS NULL
      ORDER BY time_updated DESC, id DESC
      LIMIT 1
    `).get() as { id: string } | undefined;
    sessionID = row?.id;
  } finally {
    database.close();
  }
}

if (!sessionID) {
  console.error(`Error: no OpenCode session found in ${databasePath}`);
  Deno.exit(1);
}

const repository = new OpenCodeRepository(databasePath);
const decoded = repository.getSession(sessionID);
repository.close();
if (!decoded) {
  console.error(`Error: session not found: ${sessionID}`);
  Deno.exit(1);
}

const session = analyzeSessionCache(priceSessionDetail(decoded));
const money = (value: number | undefined) =>
  value === undefined ? "-" : `$${value.toFixed(6)}`;
const integer = (value: number | undefined) =>
  value === undefined ? "-" : value.toLocaleString("en-US");
const percent = (value: number | undefined) =>
  value === undefined ? "-" : `${(value * 100).toFixed(1)}%`;
const cell = (value: string, width: number, left = false) =>
  left ? value.padEnd(width) : value.padStart(width);

console.log(`Session: ${session.id}`);
console.log(`Title:   ${session.title}`);
console.log(`DB:      ${databasePath}`);
console.log(`Models:  ${session.models.join(", ") || "unknown"}`);
console.log(
  `Cost:    ${money(session.reportedCost)} reported / ${money(session.computedCost)} computed`,
);
console.log("");

const columns = [
  ["T.C", 5, true],
  ["MODEL", 18, true],
  ["IMG", 3, false],
  ["NEW", 9, false],
  ["READ", 9, false],
  ["WRITE", 9, false],
  ["CACHED", 7, false],
  ["RETAIN", 7, false],
  ["PREV", 9, false],
  ["LOST", 9, false],
  ["OUT", 8, false],
  ["RSN", 8, false],
  ["REPORTED", 11, false],
  ["COMPUTED", 11, false],
  ["CACHE", 12, true],
] as const;
console.log(columns.map(([name, width, left]) => cell(name, width, left)).join(" "));

for (const [turnIndex, turn] of session.turns.entries()) {
  if (turnIndex > 0) console.log("");
  for (const call of turn.calls) {
    const tokens = call.tokens;
    const totalInput = tokens.uncachedInput + tokens.cacheRead +
      (tokens.cacheWrite ?? 0);
    const prior = call.cacheAssessment?.previousReusableTokens;
    const lost = prior === undefined ? undefined : Math.max(0, prior - tokens.cacheRead);
    const model = call.model.length > 18
      ? `${call.model.slice(0, 17)}~`
      : call.model;
    const values = [
      `${turn.number}.${call.callWithinTurn}`,
      model,
      call.activity.images === undefined ? "-" : "Y",
      integer(tokens.uncachedInput),
      integer(tokens.cacheRead),
      integer(tokens.cacheWrite),
      percent(totalInput === 0 ? undefined : tokens.cacheRead / totalInput),
      percent(call.cacheAssessment?.retainedRatio),
      integer(prior),
      integer(lost),
      integer(tokens.output),
      integer(tokens.reasoning),
      money(call.reportedCost),
      money(call.computedCost),
      call.cacheAssessment?.status ?? "unknown",
    ];
    console.log(
      columns.map(([, width, left], index) => cell(values[index], width, left)).join(" "),
    );
  }
}

if (session.turns.length === 0) console.log("No billable model calls found.");
