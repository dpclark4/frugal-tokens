# Local archive used to create demo database snapshots.
FRUGAL_TOKENS_DATABASE_URL=sqlite:~/.local/share/frugal-tokens/archive.sqlite

# Pages deployment configuration.
DEPLOY_API_BASE_URL=https://api.demo.frugaltokens.com
DEPLOY_PAGES_PROJECT=frugal-tokens-demo

# Railway deployment configuration.
DEPLOY_RAILWAY_SERVICE=demo-api
DEPLOY_RAILWAY_VOLUME=demo-api-volume
